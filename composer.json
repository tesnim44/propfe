{
  "name": "ibloglv/iblog",
  "description": "IBlog functional test suite",
  "type": "project",
  "autoload": {
    "psr-4": {
      "IBlog\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload-dev": {
    "psr-4": {
      "IBlog\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:integration": "vendor/bin/phpunit --testsuite Integration",
    "test:advanced": "vendor/bin/phpunit --testsuite Advanced"
  }
}
